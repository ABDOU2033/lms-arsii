@startuml Diagramme_Sequence_Gestion_Utilisateurs

' Style Enterprise Architect (EA) Classique
skinparam style strictuml
skinparam backgroundColor #FFFFFF
skinparam handwritten false
skinparam shadow false

skinparam sequence {
    ArrowColor #000000
    ArrowFontColor #000000
    ArrowFontSize 11
    ArrowFontName Arial
    
    LifeLineBorderColor #000000
    LifeLineBackgroundColor #FFFFFF
    
    ParticipantBorderColor #000000
    ParticipantBackgroundColor #FFFFE1
    ParticipantFontColor #000000
    ParticipantFontSize 12
    ParticipantFontName Arial Bold
    
    ActorBorderColor #000000
    ActorBackgroundColor #FFFFE1
    ActorFontColor #000000
    ActorFontSize 12
    ActorFontName Arial Bold
    
    BoxBorderColor #000000
    BoxBackgroundColor #FFFFE1
    BoxFontColor #000000
    BoxFontSize 11
    
    DividerBorderColor #000000
    DividerBackgroundColor #F2F3F4
    DividerFontColor #000000
    
    GroupBorderColor #000000
    GroupHeaderBackgroundColor #EAEAEA
    GroupBackgroundColor #FFFFFF
    GroupFontColor #000000
    GroupFontSize 11
    GroupBoldFont true
    
    ReferenceBorderColor #000000
    ReferenceBackgroundColor #FFFFFF
    
    SequenceLifeLineBorderThickness 1
    SequenceParticipantBorderThickness 1
    SequenceActorBorderThickness 1
}

skinparam note {
    BackgroundColor #FFFFC0
    BorderColor #000000
    FontColor #000000
    FontSize 10
    FontName Arial
}

title Diagramme de séquence — Gestion des utilisateurs par l'admin
actor "Administrateur" as Admin
boundary "admin/utilisateurs" as View
control "AdminWebController" as Ctrl
entity "User" as UserModel
database "Base de données" as DB

autonumber
Admin -> View : Accéder à la liste des utilisateurs
activate View
View -> Ctrl : utilisateurs()
activate Ctrl
Ctrl -> UserModel : all()
activate UserModel
UserModel -> DB : SELECT * FROM users
activate DB
DB --> UserModel : Liste des utilisateurs
deactivate DB
UserModel --> Ctrl : Collection d'utilisateurs
deactivate UserModel
Ctrl --> View : Vue utilisateurs.blade.php
deactivate Ctrl
View --> Admin : Liste affichée

alt Activer un compte
    Admin -> View : Cliquer sur "Activer"
    View -> Ctrl : activerUtilisateur(user)
    activate Ctrl
    Ctrl -> UserModel : update(statut='actif')
    activate UserModel
    UserModel -> DB : UPDATE users SET statut='actif'
    activate DB
    DB --> UserModel : OK
    deactivate DB
    deactivate UserModel
    Ctrl --> View : Rediriger avec message succès
    deactivate Ctrl
    View --> Admin : Statut mis à jour à "Actif"
else Désactiver un compte
    Admin -> View : Cliquer sur "Désactiver"
    View -> Ctrl : desactiverUtilisateur(user)
    activate Ctrl
    Ctrl -> UserModel : update(statut='inactif')
    activate UserModel
    UserModel -> DB : UPDATE users SET statut='inactif'
    activate DB
    DB --> UserModel : OK
    deactivate DB
    deactivate UserModel
    Ctrl --> View : Rediriger avec message succès
    deactivate Ctrl
    View --> Admin : Statut mis à jour à "Inactif"
end
deactivate View
@enduml
@startuml Diagramme_Sequence_Modification_Cours

' Style Enterprise Architect (EA) Classique
skinparam style strictuml
skinparam backgroundColor #FFFFFF
skinparam handwritten false
skinparam shadow false

skinparam sequence {
    ArrowColor #000000
    ArrowFontColor #000000
    ArrowFontSize 11
    ArrowFontName Arial
    
    LifeLineBorderColor #000000
    LifeLineBackgroundColor #FFFFFF
    
    ParticipantBorderColor #000000
    ParticipantBackgroundColor #FFFFE1
    ParticipantFontColor #000000
    ParticipantFontSize 12
    ParticipantFontName Arial Bold
    
    ActorBorderColor #000000
    ActorBackgroundColor #FFFFE1
    ActorFontColor #000000
    ActorFontSize 12
    ActorFontName Arial Bold
    
    BoxBorderColor #000000
    BoxBackgroundColor #FFFFE1
    BoxFontColor #000000
    BoxFontSize 11
    
    DividerBorderColor #000000
    DividerBackgroundColor #F2F3F4
    DividerFontColor #000000
    
    GroupBorderColor #000000
    GroupHeaderBackgroundColor #EAEAEA
    GroupBackgroundColor #FFFFFF
    GroupFontColor #000000
    GroupFontSize 11
    GroupBoldFont true
    
    ReferenceBorderColor #000000
    ReferenceBackgroundColor #FFFFFF
    
    SequenceLifeLineBorderThickness 1
    SequenceParticipantBorderThickness 1
    SequenceActorBorderThickness 1
}

skinparam note {
    BackgroundColor #FFFFC0
    BorderColor #000000
    FontColor #000000
    FontSize 10
    FontName Arial
}

title Diagramme de séquence — Modification d'un cours
actor "Enseignant" as Teacher
boundary "cours/edit.blade.php" as View
control "EnseignantController" as Ctrl
entity "Cours" as CoursModel
database "Base de données" as DB

autonumber
Teacher -> View : Cliquer sur "Modifier le cours"
activate View
View -> Ctrl : editCours(cours)
activate Ctrl
Ctrl --> View : Remplir le formulaire avec les anciennes valeurs
deactivate Ctrl

Teacher -> View : Modifier les champs et cliquer sur "Enregistrer"
View -> Ctrl : updateCours(request, cours)
activate Ctrl
Ctrl -> Ctrl : Valider les données
alt Données invalides
    Ctrl --> View : Retour avec erreurs
else Données valides
    Ctrl -> CoursModel : update(titre, description, statut)
    activate CoursModel
    CoursModel -> DB : UPDATE cours SET ... WHERE id = ?
    activate DB
    DB --> CoursModel : OK
    deactivate DB
    CoursModel --> Ctrl : OK
    deactivate CoursModel
    Ctrl --> View : Rediriger avec message succès
    View --> Teacher : Afficher le cours mis à jour
end
deactivate Ctrl
deactivate View
@enduml